{
  "name": "maestro-js",
  "version": "0.1.0",
  "type": "module",
  "description": "Human-friendly music library — write, render, and play music with simple syntax",
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin typescript",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "import": "./dist/maestro.esm.js",
      "require": "./dist/maestro.cjs.js",
      "browser": "./dist/maestro.esm.js"
    },
    "./node": {
      "import": "./dist/maestro.node.esm.js"
    }
  },
  "main": "./dist/maestro.cjs.js",
  "module": "./dist/maestro.esm.js",
  "types": "./dist/maestro.d.ts",
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
