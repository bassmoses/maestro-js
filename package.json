{
  "name": "@bassmoses/maestro-js",
  "version": "0.2.1",
  "type": "module",
  "description": "Human-friendly music library — write, render, and play music with simple syntax",
  "license": "MIT",
  "author": "Moses Bass",
  "repository": {
    "type": "git",
    "url": "https://github.com/bassmoses/maestro-js.git"
  },
  "homepage": "https://github.com/bassmoses/maestro-js#readme",
  "bugs": {
    "url": "https://github.com/bassmoses/maestro-js/issues"
  },
  "keywords": [
    "music",
    "notation",
    "midi",
    "audio",
    "composition",
    "sheet-music",
    "vexflow",
    "tone"
  ],
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin typescript",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "release": "npm version patch && npm publish",
    "release:minor": "npm version minor && npm publish",
    "release:major": "npm version major && npm publish"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/maestro.esm.js",
      "require": "./dist/maestro.cjs.js",
      "browser": "./dist/maestro.esm.js"
    },
    "./node": {
      "types": "./dist/node/index.d.ts",
      "import": "./dist/maestro.node.esm.js"
    }
  },
  "main": "./dist/maestro.cjs.js",
  "module": "./dist/maestro.esm.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/maestro.umd.min.js",
  "jsdelivr": "./dist/maestro.umd.min.js",
  "files": [
    "dist",
    "!dist/**/__tests__"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jsdom": "^28.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "fast-xml-parser": "^5.7.2",
    "jsdom": "^29.1.0",
    "midi-writer-js": "^3.2.1",
    "tone": "^15.1.22",
    "vexflow": "^5.0.0"
  },
  "peerDependencies": {
    "sharp": ">=0.33.0"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    }
  }
}
